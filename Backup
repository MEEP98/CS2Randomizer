```html
<!DOCTYPE html>
<html lang="da">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CS2 Challenge Generator</title>

<style>

body{
margin:0;
background:#121212;
color:white;
font-family:Segoe UI;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
}

.container{
background:#1f1f1f;
padding:25px;
border-radius:12px;
max-width:420px;
width:90%;
text-align:center;
box-shadow:0 0 15px rgba(0,255,255,0.2);
}

button{
width:100%;
padding:14px;
margin-top:10px;
border:none;
border-radius:8px;
font-size:16px;
font-weight:bold;
cursor:pointer;
}

.primary{background:#00ffff;color:#111;}
.win{background:#28a745;color:white;}
.loss{background:#dc3545;color:white;}
.danger{background:#ff4c4c;color:white;}

.challengeTitle{font-size:22px;font-weight:bold;margin-bottom:10px;}
.challengeText{font-size:18px;margin-bottom:20px;}

.scoreboard{
display:flex;
gap:10px;
margin-top:15px;
}

.scoreBox{
flex:1;
padding:12px;
border-radius:8px;
}

.winBox{background:#1f5f2e;}
.lossBox{background:#5f1f1f;}

</style>
</head>

<body>

<div class="container">

<h1>CS2 Challenges</h1>

<div id="setup">

<p>Vælg Game Mode</p>

<button class="primary" onclick="selectMode('Competitive')">Competitive</button>
<button class="primary" onclick="selectMode('Wingman')">Wingman</button>
<button class="primary" onclick="selectMode('Druk')">Druk</button>

</div>

<div id="game" style="display:none;">

<p><b>Mode:</b> <span id="modeDisplay"></span></p>
<p><b>Map:</b> <span id="mapDisplay"></span></p>
<p><b>Runde:</b> <span id="round"></span></p>
<p><b>Side:</b> <span id="side"></span></p>

<div id="challenge"></div>

<button class="win" onclick="win()">Vandt runde</button>
<button class="loss" onclick="lose()">Tabte runde</button>

<div class="scoreboard">

<div class="scoreBox winBox">
Wins
<div id="wins">0</div>
</div>

<div class="scoreBox lossBox">
Losses
<div id="losses">0</div>
</div>

</div>

<button class="danger" onclick="endGame()">Afslut kamp</button>

</div>

</div>


<script>

let round=1
let side=""
let wins=0
let losses=0
let currentMode=""
let currentMap=""

const mapsByMode={

Competitive:[
"Anubis","Overpass","Inferno","Mirage","Dust 2",
"Nuke","Ancient","Train","Vertigo","Office","Italy","Andet"
],

Wingman:[
"Overpass","Vertigo","Nuke","Inferno","Andet"
],

Druk:[]

}



const standardChallenges=[

{title:"Tag en slapper",text:"Du må kun liste denne runde"},
{title:"Rush B",text:"Du SKAL rush uden at stoppe"},
{title:"Ingen reload",text:"Reload kun når magasinet er helt tomt"},
{title:"Headshot only",text:"Du må kun skyde efter hovedet"},
{title:"Granatfest",text:"Brug alle dine granater inden 30 sek"}

]



const competitiveMapChallenges={

"Anubis":[
{title:"Map Test",text:"Competitive Anubis virker"},
{title:"Map Test",text:"Anubis challenge test"},
{title:"Map Test",text:"Endnu en Anubis test"}
],

"Overpass":[
{title:"Map Test",text:"Competitive Overpass virker"},
{title:"Map Test",text:"Overpass challenge test"},
{title:"Map Test",text:"Endnu en Overpass test"}
],

"Inferno":[
{title:"Map Test",text:"Competitive Inferno virker"},
{title:"Map Test",text:"Inferno challenge test"}
],

"Mirage":[
{title:"Map Test",text:"Competitive Mirage virker"},
{title:"Map Test",text:"Mirage challenge test"},
{title:"Map Test",text:"Endnu en Mirage test"}
],

"Dust 2":[
{title:"Map Test",text:"Competitive Dust2 virker"},
{title:"Map Test",text:"Dust2 challenge test"}
],

"Nuke":[
{title:"Map Test",text:"Competitive Nuke virker"},
{title:"Map Test",text:"Nuke challenge test"}
],

"Ancient":[
{title:"Map Test",text:"Competitive Ancient virker"}
],

"Train":[
{title:"Map Test",text:"Competitive Train virker"}
],

"Vertigo":[
{title:"Map Test",text:"Competitive Vertigo virker"}
],

"Office":[
{title:"Map Test",text:"Competitive Office virker"}
],

"Italy":[
{title:"Map Test",text:"Competitive Italy virker"}
],

"Andet":[
{title:"Map Test",text:"Competitive Andet virker"}
]

}



const wingmanMapChallenges={

"Overpass":[
{title:"Map Test",text:"Wingman Overpass virker"}
],

"Vertigo":[
{title:"Map Test",text:"Wingman Vertigo virker"}
],

"Nuke":[
{title:"Map Test",text:"Wingman Nuke virker"}
],

"Inferno":[
{title:"Map Test",text:"Wingman Inferno virker"}
],

"Andet":[
{title:"Map Test",text:"Wingman Andet virker"}
]

}



function selectMode(mode){

currentMode=mode

if(mode==="Druk"){

document.getElementById("setup").innerHTML=`

<p>Kommer snart</p>
<button class="danger" style="margin-top:15px;" onclick="resetSetup()">Tilbage</button>

`
return
}

let mapButtons=mapsByMode[mode].map(m=>`<button class="primary" onclick="selectMap('${m}')">${m}</button>`).join("")

document.getElementById("setup").innerHTML=`

<p>Vælg Map (${mode})</p>
${mapButtons}
<button class="danger" style="margin-top:15px;" onclick="resetSetup()">Tilbage</button>

`

}



function resetSetup(){

location.reload()

}



function selectMap(map){

currentMap=map

document.getElementById("setup").innerHTML=`

<p>Valgt Mode: ${currentMode}</p>
<p>Valgt Map: ${currentMap}</p>

<p>Vælg start side</p>

<button class="primary" onclick="startGame('CT')">Start som CT</button>
<button class="primary" onclick="startGame('T')">Start som T</button>

<button class="danger" style="margin-top:15px;" onclick="resetSetup()">Tilbage</button>

`

}



function randomChallenge(){

let standardPool = standardChallenges

let mapPool = []

if(currentMode==="Competitive"){
mapPool = competitiveMapChallenges[currentMap] || []
}

if(currentMode==="Wingman"){
mapPool = wingmanMapChallenges[currentMap] || []
}

let useMap = Math.random() < 0.5

let pool

if(useMap && mapPool.length>0){
pool = mapPool
}else{
pool = standardPool
}

return pool[Math.floor(Math.random()*pool.length)]

}



function startGame(s){

side=s

document.getElementById("modeDisplay").innerText=currentMode
document.getElementById("mapDisplay").innerText=currentMap

document.getElementById("setup").style.display="none"
document.getElementById("game").style.display="block"

updateUI()

}



function updateUI(){

document.getElementById("round").innerText=round
document.getElementById("side").innerText=side

let c=randomChallenge()

document.getElementById("challenge").innerHTML=`

<div class="challengeTitle">${c.title}</div>
<div class="challengeText">${c.text}</div>

`

}



function win(){

wins++
document.getElementById("wins").innerText=wins
nextRound()

}

function lose(){

losses++
document.getElementById("losses").innerText=losses
nextRound()

}



function nextRound(){

round++
updateUI()

}



function endGame(){

location.reload()

}

</script>

</body>
</html>
```
